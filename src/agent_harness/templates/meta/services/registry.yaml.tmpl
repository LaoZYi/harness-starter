# 服务注册表 — {{project_name}}
#
# 列出所有微服务及其基本信息，保持与实际部署一致。
# 新增或下线服务时必须同步更新本文件。
#
# 字段说明：
#   repo:    本地仓库路径（支持 ~ 和相对路径，如 ../payment-service）
#   domain:  所属业务领域（对应 business/domains/ 下的目录名）
#   owner:   负责团队或个人
#   summary: 一句话描述职责
#   port:    服务端口（可选）
#   status:  active / deprecated / planned
#
# 提示：repo 必须是本地路径，harness sync 会直接往该目录写入文件。
#       相对路径基于本 meta 仓库目录解析（如 ../payment-service、../../other/svc 均可）。

# payment-service:
#   repo: ../payment-service
#   domain: payment
#   owner: 支付团队
#   summary: 处理支付创建、查询和退款
#   port: 8001
#   status: active

